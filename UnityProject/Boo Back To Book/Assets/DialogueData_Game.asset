  lines:
  - ID: 
    Clip: {fileID: 8300000, guid: 59a75fab76999684880208a2dcd9c281, type: 3}
    SubTitleText: "\u304A\u304B\u3057\u3044...\u304A\u5316\u3051\u304C\u3044\u308B\u3088\u3046\u306B\u306F\u898B\u3048\u306D\u3047\u306A..."
  - ID: 
    Clip: {fileID: 8300000, guid: 7a752a2144d989445b824af05f060b30, type: 3}
    SubTitleText: "\u3084\u3070\u3044...\u307E\u305F\u3080\u305A\u3080\u305A\u3057\u3066\u304D\u305F"
  - ID: 
    Clip: {fileID: 8300000, guid: 7a752a2144d989445b824af05f060b30, type: 3}
    SubTitleText: "\u3084\u3063\u3071\u308A\u3044\u305F\u304B\uFF01"
  - ID: 
    Clip: {fileID: 0}
    SubTitleText: "\u5371\u306A\u3044\u304B\u3089\u4ECA\u306F\u52D5\u304F\u306A\u3088\uFF01"
  - ID: 
    Clip: {fileID: 0}
    SubTitleText: "\u4E00\u65E6\u843D\u3061\u7740\u3044\u305F\u306A...\u5927\u4E08\u592B\u304B\uFF1F"
  - ID: 
    Clip: {fileID: 8300000, guid: 59a75fab76999684880208a2dcd9c281, type: 3}
    SubTitleText: "\u304A\u3044\u3001\u3053\u306E\u90E8\u5C4B\u3055\u3063\u304D\u3068\u306A\u3093\u304B\u9055\u304F\u306D\u3047\u304B\uFF1F"
  - ID: 
    Clip: {fileID: 0}
    SubTitleText: "\u3055\u3063\u304D\u307F\u305F\u3044\u306B\u201D\u3044\u305F\u305A\u3089\u201D\u3092\u306A\u304A\u3057\u3066\u304A\u5316\u3051\u3092\u6355\u307E\u3048\u3066\u304F\u308C\uFF01"
  - ID: 
    Clip: {fileID: 0}
    SubTitleText: "\u5236\u9650\u6642\u9593\u306F3\u5206\u3060\uFF01"
  - ID: 
    Clip: {fileID: 8300000, guid: 5c5f01bd25c6aee4f97ddc7083902475, type: 3}
    SubTitleText: "\u3044\u304F\u305E\uFF013...2...1...\u30B9\u30BF\u30FC\u30C8\uFF01"
  - ID: 
    Clip: {fileID: 0}
    SubTitleText: "\u3044\u304F\u305E\uFF013...2...1...\u30B9\u30BF\u30FC\u30C8\uFF01"
  - ID: 
    Clip: {fileID: 8300000, guid: 5266d70ec92292846aec684529216e6c, type: 3}
    SubTitleText: "\u3046\u307E\u3044\u305E\uFF01\u3042\u30682\u4F53\u304F\u3089\u3044\u306E\u6C17\u914D\u304C\u3059\u308B\u306A\u3041.."
  - ID: 
    Clip: {fileID: 8300000, guid: 6299e9c774a37b640879f719361744de, type: 3}
    SubTitleText: "\u3044\u3044\u305E\uFF01\u305D\u306E\u8ABF\u5B50\u3060\uFF01\u6B8B\u308A1\u4F53\u3060\uFF01"
  - ID: 
    Clip: {fileID: 8300000, guid: 6299e9c774a37b640879f719361744de, type: 3}
    SubTitleText: "\u3088\u304F\u3084\u3063\u305F\uFF01\u4ECA\u306E\u304C\u6700\u5F8C\u306E\u304A\u5316\u3051\u3060\uFF01"
