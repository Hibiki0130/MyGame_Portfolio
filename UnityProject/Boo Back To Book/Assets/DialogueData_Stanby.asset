  - ID: 
    Clip: {fileID: 8300000, guid: 0f79887a6f1a4fc4db06500bd61dc8b3, type: 3}
    SubTitleText: "\u304A\u30FC\u3044"
  - ID: 
    Clip: {fileID: 8300000, guid: fec2ce4c0beb64c4d990849388bd4d16, type: 3}
    SubTitleText: "\u3053\u3053\u3060\u3088\uFF01\u3053\u3053\uFF01"
  - ID: 
    Clip: {fileID: 8300000, guid: 59a75fab76999684880208a2dcd9c281, type: 3}
    SubTitleText: "\u4FFA\u306B\u3064\u3044\u3066\u3044\u308B\u57C3\u3092\u6255\u3063\u3066\u304F\u308C\u306A\u3044\u304B\uFF1F"
  - ID: 
    Clip: {fileID: 8300000, guid: 0f79887a6f1a4fc4db06500bd61dc8b3, type: 3}
    SubTitleText: "\u5F8C\u308D\u3060\uFF01\u3053\u3063\u3061\u307E\u3067\u6B69\u3044\u3066\u304D\u3066\u304F\u308C\uFF01"
  - ID: 
    Clip: {fileID: 8300000, guid: 59a75fab76999684880208a2dcd9c281, type: 3}
    SubTitleText: "\u304A\u5316\u3051\u305F\u3061\u306F\u3082\u306E\u306B\u6191\u4F9D\u3057\u3066\u3044\u305F\u305A\u3089\u3059\u308B\u3093\u3060..."
  - ID: 
    Clip: {fileID: 8300000, guid: 8191c19a1f0638f49935fc075725e859, type: 3}
    SubTitleText: "\u3060\u304B\u3089\u305D\u308C\u3092\u898B\u3064\u3051\u3066\u5143\u306B\u623B\u3057\u3066\u307B\u3057\u3044\u3093\u3060\uFF01"
  - ID: 
    Clip: {fileID: 8300000, guid: 59a75fab76999684880208a2dcd9c281, type: 3}
    SubTitleText: "\u304A\u3063\u3068..\u3053\u308C\u306F\u304A\u5316\u3051\u306E\u4ED5\u696D\u304B\u3082\u306A"
  - ID: 
    Clip: {fileID: 0}
    SubTitleText: "\u3061\u3087\u3063\u3068\u96FB\u8A71\u306B\u51FA\u3066\u307F\u3066\u304F\u308C"
  - ID: 
    Clip: {fileID: 0}
    SubTitleText: "\u96FB\u8A71\u3092\u5143\u306B\u623B\u3057\u3066\u307F\u3066\u304F\u308C"
  - ID: 
    Clip: {fileID: 8300000, guid: 6299e9c774a37b640879f719361744de, type: 3}
    SubTitleText: "\"\u3044\u305F\u305A\u3089\"\u3092\u5143\u306B\u623B\u3059\u3068\u304A\u5316\u3051\u304C\u51FA\u3066\u304F\u308B\u305E\uFF01"
  - ID: 
    Clip: {fileID: 0}
    SubTitleText: "\u65E9\u304F\u8FFD\u3044\u304B\u3051\u3088\u3046\u305C"
  - ID: 
    Clip: {fileID: 8300000, guid: 59a75fab76999684880208a2dcd9c281, type: 3}
    SubTitleText: "\u6016\u304C\u3063\u3066\u9003\u3052\u3066\u305F\u3063\u3066\uFF1F\u3042\u308C\u306F\u305F\u3060\u9A5A\u3044\u305F\u3060\u3051\u3060\uFF01\uFF01"
  - ID: 
    Clip: {fileID: 8300000, guid: 59a75fab76999684880208a2dcd9c281, type: 3}
    SubTitleText: "\u3053\u306E\u6249\u3001\u30C9\u30A2\u30CE\u30D6\u304C\u3042\u3063\u305F\u306F\u305A\u306A\u3093\u3060\u304C\u3001\u3053\u308C\u3082\u3044\u305F\u305A\u3089\u304B\uFF1F"
  - ID: 
    Clip: {fileID: 8300000, guid: 5266d70ec92292846aec684529216e6c, type: 3}
    SubTitleText: "\u304A\u3001\u898B\u3064\u3051\u305F\u304B\uFF01\u3058\u3083\u3042\u5143\u306B\u623B\u305D\u3046\u305C"
  - ID: 
    Clip: {fileID: 0}
    SubTitleText: "\u30C9\u30A2\u30CE\u30D6\u3092\u5143\u306B\u623B\u3057\u3066\u304F\u308C"
  - ID: 
    Clip: {fileID: 8300000, guid: 5266d70ec92292846aec684529216e6c, type: 3}
    SubTitleText: "\u3088\u304F\u3084\u3063\u305F\uFF01\uFF01\u3053\u3053\u3067\u4FFA\u306E\u51FA\u756A\u3060\u306A\uFF01"
  - ID: 
    Clip: {fileID: 8300000, guid: 8191c19a1f0638f49935fc075725e859, type: 3}
    SubTitleText: "\u304A\u524D\u306E\u4E21\u624B\u3092\u304B\u308A\u308B\u305C\uFF01\u958B\u3044\u305F\u308A\u9589\u3058\u305F\u308A\u3067\u304D\u308B\u304B\uFF1F"
  - ID: 
    Clip: {fileID: 0}
    SubTitleText: "\u4E21\u624B\u3092\u4F7F\u3063\u3066\u958B\u3044\u305F\u308A\u9589\u3058\u305F\u308A\u3067\u304D\u308B\u304B\uFF1F"
  - ID: 
    Clip: {fileID: 8300000, guid: 6299e9c774a37b640879f719361744de, type: 3}
    SubTitleText: "\u305D\u306E\u8ABF\u5B50\u3060\uFF01"
  - ID: 
    Clip: {fileID: 8300000, guid: 5c5f01bd25c6aee4f97ddc7083902475, type: 3}
    SubTitleText: "\u4FFA\u3067\u304A\u5316\u3051\u3092\u306F\u3055\u3093\u3067\u6355\u307E\u3048\u3066\u304F\u308C\uFF01"
  - ID: 
    Clip: {fileID: 8300000, guid: f19ee91e02d081941b7773a21cd93a22, type: 3}
    SubTitleText: "\u4F55\u3068\u304B\u6355\u7372\u3067\u304D\u305F\u3088\u3046\u3060\u306A.."
  - ID: 
    Clip: {fileID: 8300000, guid: 59a75fab76999684880208a2dcd9c281, type: 3}
    SubTitleText: "\u3053\u306E\u6249\u306E\u5148\u304B\u3089\u3082\u304A\u5316\u3051\u306E\u6C17\u914D\u304C\u3059\u308B..."
  - ID: 
    Clip: {fileID: 8300000, guid: 5c5f01bd25c6aee4f97ddc7083902475, type: 3}
    SubTitleText: "\u5165\u3063\u3066\u307F\u3088\u3046\u305C\uFF01"
  - ID: 
    Clip: {fileID: 0}
    SubTitleText: "\u3053\u306E\u8ABF\u5B50\u3067\u6B8B\u308A\u306E\u304A\u3070\u3051\u3082\u6355\u307E\u3048\u3088\u3046\u305C\uFF01"
  - ID: 
    Clip: {fileID: 8300000, guid: 0f79887a6f1a4fc4db06500bd61dc8b3, type: 3}
    SubTitleText: "\u3053\u3063\u3061\u3060\u305C\uFF01"
  - ID: 
    Clip: {fileID: 8300000, guid: 59a75fab76999684880208a2dcd9c281, type: 3}
    SubTitleText: "\u3084\u3063\u3071\u308A\u304A\u5316\u3051\u304C\u3044\u308B\u6C17\u304C\u3059\u308B..."
  - ID: 
    Clip: {fileID: 0}
    SubTitleText: "\u602A\u3057\u3044\u3068\u3053\u308D\u304C\u306A\u3044\u304B\u3001\u4E00\u7DD2\u306B\u90E8\u5C4B\u3092\u898B\u56DE\u3063\u3066\u304F\u308C"
  - ID: 
    Clip: {fileID: 0}
    SubTitleText: "\u6CE8\u610F\u3057\u3066\u9685\u3005\u307E\u3067\u3088\u304F\u898B\u308B\u3093\u3060\u305E\uFF01"
  - ID: 
    Clip: {fileID: 8300000, guid: 8191c19a1f0638f49935fc075725e859, type: 3}
    SubTitleText: "\u30C6\u30EC\u30D3\u306F\u898B\u308B\u304B\uFF1F\u4FFA\u306F\u30C9\u30E9\u30DE\u304C\u597D\u304D\u3060\u306A"
  - ID: 
    Clip: {fileID: 8300000, guid: 59a75fab76999684880208a2dcd9c281, type: 3}
    SubTitleText: "\u30C4\u30DC\u306B\u304A\u91D1\u304C\u5165\u3063\u3066\u306A\u3044\u304B\u306A..."
  - ID: 
    Clip: {fileID: 0}
    SubTitleText: "\u898B\u3064\u3051\u3066\u3082\u3084\u3089\u306D\u3048\u305E"
  - ID: 
    Clip: {fileID: 8300000, guid: 6299e9c774a37b640879f719361744de, type: 3}
    SubTitleText: "\u4FFA\u306E\u4EF2\u9593\u304C\u305F\u304F\u3055\u3093\u3060\u306A..\u3088\u304A\uFF01\u5143\u6C17\u3057\u3066\u308B\u304B\uFF1F"
  - ID: 
    Clip: {fileID: 8300000, guid: 5266d70ec92292846aec684529216e6c, type: 3}
    SubTitleText: "\u5ECA\u4E0B\u306B\u3082\u90E8\u5C4B\u306B\u3082\u3053\u306E\u5C4B\u6577\u306F\u7D75\u304C\u3044\u3063\u3071\u3044\u3060\u306A"
